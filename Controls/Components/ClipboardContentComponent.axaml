<ci:ComponentBase
    x:Class="SystemTools.Controls.Components.ClipboardContentComponent"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SystemTools.Controls.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:SystemTools.Models.ComponentSettings"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:TypeArguments="settings:ClipboardContentSettings"
    Loaded="ClipboardContentComponent_OnLoaded"
    Unloaded="ClipboardContentComponent_OnUnloaded"
    mc:Ignorable="d">
    <Grid DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:ClipboardContentComponent}}">
        <TextBlock Text="{Binding ClipboardContent}"
                   VerticalAlignment="Center"
                   TextWrapping="NoWrap"
                   TextTrimming="CharacterEllipsis" />
    </Grid>
</ci:ComponentBase>
