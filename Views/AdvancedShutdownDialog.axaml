<Window x:Class="SystemTools.Views.AdvancedShutdownDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ci="http://classisland.tech/schemas/xaml/core"
        Width="440"
        Height="290"
        CanResize="False"
        SystemDecorations="Full"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Title="高级计时关机">
    <Border Margin="14" Padding="16" CornerRadius="12"
            Background="{DynamicResource LayerFillColorAltBrush}">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ci:FluentIcon Glyph="&#xE4C4;" FontSize="24" VerticalAlignment="Center" />
                <StackPanel>
                    <TextBlock Text="关机计划已创建" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="你可以确认、取消或延长本次计划"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" Padding="12" CornerRadius="8"
                    Background="{DynamicResource SystemFillColorAttentionBackgroundBrush}">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="CountdownTextBlockElement"
                               FontSize="20"
                               FontWeight="Bold"
                               Text="将在2分00秒后关机……" />
                    <ProgressBar x:Name="CountdownProgressBarElement" Height="6" Minimum="0" Maximum="3000" Value="3000" />
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Text="若要继续使用电脑，请选择“取消计划”或“延长时间”。"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="ImmediateShutdownButtonElement" Content="立即关机" MinWidth="92" />
                <Button x:Name="ReadButtonElement" Content="已阅" MinWidth="84" Classes="accent" IsDefault="True" />
                <Button x:Name="CancelPlanButtonElement" Content="取消计划" MinWidth="92" />
                <Button x:Name="ExtendButtonElement" Content="延长时间" MinWidth="92" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
